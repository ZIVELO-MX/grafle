# Production defaults — committed, applies to production builds
# Update VITE_APP_URL here or override it in Vercel's Environment Variables settings.
# Vercel also injects VERCEL_PROJECT_PRODUCTION_URL and VERCEL_URL as automatic fallbacks
# (see docs/urls-and-opengraph.md).
VITE_APP_URL=https://grafle.vercel.app
VITE_ALLOW_FUTURE_PUZZLES=false
VITE_SKIP_START_SCREEN=false
