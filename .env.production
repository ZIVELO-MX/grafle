# Production defaults — committed, applies to production builds.
# DO NOT set VITE_APP_URL here — on Vercel it would override VERCEL_URL on preview deploys.
# To set the canonical URL for production, use Vercel dashboard →
# Settings → Environment Variables → VITE_APP_URL, scoped to "Production" only.
# See docs/urls-and-opengraph.md for the full resolution order.
VITE_ALLOW_FUTURE_PUZZLES=false
VITE_SKIP_START_SCREEN=false
