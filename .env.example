# Grafle environment variables — copia este archivo a .env.local para overrides personales.
# Docs completos: docs/feature-flags.md y docs/urls-and-opengraph.md

# URL canónica de la app. Usada en OG tags, share text, y workbox.
# En Vercel se puede setear desde el dashboard (Environment Variables).
# Si no está seteada, se usa VERCEL_PROJECT_PRODUCTION_URL > VERCEL_URL > localhost.
# Dev default: http://localhost:5173  |  Prod default: https://grafle.vercel.app
VITE_APP_URL=http://localhost:5173

# Permite navegar a puzzles más allá de la fecha de hoy.
# Dev default: true  |  Prod default: false
VITE_ALLOW_FUTURE_PUZZLES=false

# Salta la pantalla de inicio y entra directo al puzzle.
# Dev default: true  |  Prod default: false
VITE_SKIP_START_SCREEN=false
